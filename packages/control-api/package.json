    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "express": "^4.21.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "supertest": "^7.1.1",
    "@types/supertest": "^6.0.2",
    "@pi-mission-control/worker": "0.1.0"
  }
}